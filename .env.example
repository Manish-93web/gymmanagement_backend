# ============================================================
# GYM MANAGEMENT SYSTEM — BACKEND
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/gym-management
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/gym-management
MONGODB_URI=mongodb://localhost:27017/gym-management
MONGODB_TEST_URI=mongodb://localhost:27017/gym-management-test

# ── Redis ─────────────────────────────────────────────────────
# Set USE_REDIS_MOCK=true to skip Redis entirely (development)
USE_REDIS_MOCK=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────
# Use long random strings in production (32+ chars)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-a-long-random-refresh-secret
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS & Frontend ───────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Session ───────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-session-secret

# ── Cloudinary (Image Uploads) ───────────────────────────────
# Leave blank to use local-disk fallback (public/uploads/)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Payment Gateways ──────────────────────────────────────────
# Razorpay (Indian payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Stripe (International payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourgym.com
EMAIL_FROM_NAME=Gym Management System

# ── SMS — Twilio ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── WhatsApp API ──────────────────────────────────────────────
# Compatible with WA Business API / third-party providers
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# ── OpenAI (AI CRM features) ──────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# ── Google OAuth (Calendar / Gmail sync) ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ── Zoom (Virtual classes) ────────────────────────────────────
ZOOM_API_KEY=
ZOOM_API_SECRET=

# ── File Upload ───────────────────────────────────────────────
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/pdf

# ── OTP Settings ──────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# ── Backup ────────────────────────────────────────────────────
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
